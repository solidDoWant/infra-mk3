+# --- GPU metrics integration (Level Zero Sysman via the repo's gpu_metrics
+# pybind11 module). Falls back to a no-op if the module isn't installed or
+# the runtime device isn't a GPU. Counters used:
+#   - engines[].active_time / engines[].timestamp (microseconds, monotonic)
+#       → busy fraction over a window
+#   - power[].energy / power[].timestamp (microJoules / microseconds, monotonic)
+#       → average watts over a window
+#   - memory[].used / total (bytes, snapshot)
+#   - clocks_mhz[] (snapshot)
+#   - temperature[] (snapshot, Celsius)
+#
+# Level Zero engine type enum (ZES_ENGINE_GROUP_*):
+#   0 = ALL, 1 = COMPUTE_ALL, 2 = MEDIA_ALL, 3 = COPY_ALL, 4 = RENDER_ALL,
+#   5 = 3D_RENDER_ALL, plus _SINGLE variants per engine instance.
+_GPU_METRICS_PROBED = False
+_gpu_metrics_mod = None
+
+
+def _get_gpu_metrics_mod():
+    global _GPU_METRICS_PROBED, _gpu_metrics_mod
+    if not _GPU_METRICS_PROBED:
+        _GPU_METRICS_PROBED = True
+        try:
+            import gpu_metrics as _mod  # type: ignore[import-not-found]
+            _gpu_metrics_mod = _mod
+        except Exception as exc:
+            logger.info(f"gpu_metrics module unavailable, GPU load logging disabled: {exc}")
+            _gpu_metrics_mod = None
+    return _gpu_metrics_mod
+
+
+def _gpu_snapshot() -> Optional[dict]:
+    mod = _get_gpu_metrics_mod()
+    if mod is None:
+        return None
+    try:
+        data = mod.get_gpu_metrics()
+        return data if data else None
+    except Exception as exc:
+        logger.debug(f"gpu_metrics snapshot failed: {exc}")
+        return None
+
+
+def _pick_compute_engine(engines: list) -> Optional[dict]:
+    """Pick the most representative engine for compute work: prefer
+    COMPUTE_ALL (type=1), then ALL (type=0), then the first available."""
+    if not engines:
+        return None
+    for e in engines:
+        if e.get("type") == 1:
+            return e
+    for e in engines:
+        if e.get("type") == 0:
+            return e
+    return engines[0]
+
+
+def _format_gpu_delta(before: Optional[dict], after: Optional[dict]) -> str:
+    """Format per-device GPU usage from two snapshots. Returns "" if no
+    usable delta can be computed."""
+    if not before or not after:
+        return ""
+    parts: list[str] = []
+    for dev_id in sorted(after.keys()):
+        if dev_id not in before:
+            continue
+        b, a = before[dev_id], after[dev_id]
+        bits: list[str] = []
+
+        # Compute busy % from engine activeTime / timestamp delta.
+        eb = _pick_compute_engine(b.get("engines") or [])
+        ea = _pick_compute_engine(a.get("engines") or [])
+        if eb and ea:
+            dt = ea.get("timestamp", 0) - eb.get("timestamp", 0)
+            da = ea.get("active_time", 0) - eb.get("active_time", 0)
+            if dt > 0:
+                bits.append(f"busy={100.0 * da / dt:.0f}%")
+
+        # Average watts from energy counter delta. energy is microJoules,
+        # timestamp is microseconds → microJ/microS = Watts.
+        pb = (b.get("power") or [None])[0]
+        pa = (a.get("power") or [None])[0]
+        if pb and pa:
+            dt = pa.get("timestamp", 0) - pb.get("timestamp", 0)
+            de = pa.get("energy", 0) - pb.get("energy", 0)
+            if dt > 0:
+                bits.append(f"pwr={de / dt:.1f}W")
+
+        # VRAM used (snapshot at end-of-window).
+        mems = a.get("memory") or []
+        if mems and isinstance(mems[0], dict):
+            used = mems[0].get("used", 0)
+            total = mems[0].get("total", 0)
+            if total > 0:
+                bits.append(f"vram={used / (1024 ** 3):.2f}/{total / (1024 ** 3):.2f}GB")
+
+        clocks = a.get("clocks_mhz") or []
+        if clocks:
+            bits.append(f"clk={int(clocks[0])}MHz")
+
+        temps = a.get("temperature") or []
+        if temps:
+            bits.append(f"temp={int(temps[0])}C")
+
+        if bits:
+            name = a.get("name") or f"GPU{dev_id}"
+            parts.append(f"{name}[{' '.join(bits)}]")
+    return " ".join(parts)
+
+
+def _is_gpu_device(device: Optional[str]) -> bool:
+    return bool(device) and "GPU" in str(device).upper()
+
