+def _format_subtitles(segments: List[Dict[str, Any]], fmt: str) -> str:
+    """Render `{start, end, text}` segments as SRT or WebVTT."""
+    def hms(t: float) -> str:
+        if t < 0:
+            t = 0.0
+        h, rem = divmod(t, 3600)
+        m, s = divmod(rem, 60)
+        ms = int(round((s - int(s)) * 1000))
+        if ms == 1000:  # rounding lift
+            ms, s = 0, int(s) + 1
+        sep = "." if fmt == "vtt" else ","
+        return f"{int(h):02d}:{int(m):02d}:{int(s):02d}{sep}{ms:03d}"
+
+    lines: List[str] = []
+    if fmt == "vtt":
+        lines.append("WEBVTT")
+        lines.append("")
+    cue = 0
+    for seg in segments:
+        text = (seg.get("text") or "").strip()
+        start = float(seg.get("start") or 0.0)
+        end = float(seg.get("end") or 0.0)
+        if not text or end <= start:
+            continue
+        cue += 1
+        if fmt == "srt":
+            lines.append(str(cue))
+        lines.append(f"{hms(start)} --> {hms(end)}")
+        lines.append(text)
+        lines.append("")
+    return "\n".join(lines) + ("\n" if lines and lines[-1] != "" else "")
+
