# {{ ansible_managed }}
#
# Virtual library mirroring the real hardware's INQUIRY identity (IBM
# 3573-TL library, ULT3580-TD6 drives rev J450 — see `lsscsi` on this host)
# so dry runs exercise production-identical device identification. Unit
# serial numbers are deliberately DISTINCT from the real hardware (XYZZY_*)
# so a virtual device can never be mistaken for a real one. Topology
# divergence, accepted: the real TS3200 dual-paths its changer as LUN 1
# behind each drive; the virtual library sits on its own target — the
# tape-archiver dry-run path only needs one changer + two drives.
VERSION: 5

Library: {{ mhvtl_library_id }} CHANNEL: 00 TARGET: 00 LUN: 00
 Vendor identification: IBM
 Product identification: 3573-TL
 Product revision level: F.01
 Unit serial number: XYZZY_A
 NAA: 10:22:33:44:ab:00:00:00
 Home directory: {{ mhvtl_home }}
 PERSIST: False
 Backoff: 400

{% for drive_id in mhvtl_drive_ids %}
Drive: {{ drive_id }} CHANNEL: 00 TARGET: {{ '%02d' | format(loop.index) }} LUN: 00
 Library ID: {{ mhvtl_library_id }} Slot: {{ '%02d' | format(loop.index) }}
 Vendor identification: IBM
 Product identification: ULT3580-TD6
 Product revision level: J450
 Unit serial number: XYZZY_A{{ loop.index }}
 NAA: 10:22:33:44:ab:00:{{ '%02d' | format(loop.index) }}:00
 Compression: factor 1 enabled 1
 Compression type: lzo
 Backoff: 400

{% endfor %}
