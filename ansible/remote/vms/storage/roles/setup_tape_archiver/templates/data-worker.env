# {{ ansible_managed }}
#
# Run configuration for the tape-archiver data worker. Read by both the
# systemd unit (EnvironmentFile) and `docker run --env-file`, so it is the
# single source of run configuration — nothing is hardcoded in the unit.

# Selects the data task queue and the bulk-data activity set (SPEC §4.1).
ROLE=data

# Temporal frontend gRPC, through the internal gateway (terminate +
# re-encrypt, same pattern as Teleport — see
# cluster/gitops/data/temporal/app/grpc-route.yaml). The gateway serves a
# publicly-trusted cert, so the image's bundled system roots verify it — no
# custom CA or server-name override needed.
TEMPORAL_ADDRESS={{ tape_archiver_temporal_address }}
TEMPORAL_NAMESPACE={{ tape_archiver_temporal_namespace }}
TEMPORAL_TLS=true

# JWT-SVID renewed by tape-archiver-tbot.service, bind-mounted into the
# container. The file:// form is re-read on every RPC, so tbot's renewals are
# picked up without a restart.
TEMPORAL_API_KEY=file:///var/run/teleport/jwt/jwt_svid

# Staging root for the Prepare phase — a plain subdirectory of the `archive`
# dataset, under the bind-mounted pool so it is visible in the container.
TAPE_STAGING_DIR={{ tape_archiver_staging_dir }}

# democratic-csi's datasetParentName, prepended to relative CSI
# snapshotHandles to rebuild absolute ZFS snapshot paths when a run names k8s
# sources.
TAPE_K8S_DATASET_PARENT={{ tape_archiver_k8s_dataset_parent }}

{% if tape_archiver_discord_webhook_url is defined %}
# Discord webhook for run failure alerts and report/ISO delivery.
DISCORD_FAILURE_WEBHOOK_URL={{ tape_archiver_discord_webhook_url }}
{% else %}
# tape_archiver_discord_webhook_url is not set in the (SOPS) group vars, so
# failure alerting is disabled.
{% endif %}

# Prometheus /metrics, scraped by the cluster's vmagent (see
# cluster/gitops/monitoring/exporters/cluster-external/static-scrape.yaml).
METRICS_ADDR=:9090
# Health endpoints targeted by the image HEALTHCHECK.
HEALTH_ADDR=:8080
